{
  "name": "Java SetMeal POS",
  "image": "mcr.microsoft.com/devcontainers/java:1-21-bullseye",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack"
      ]
    }
  },
  // Compiles all Java files from 'src' into a 'bin' folder on startup
  "onCreateCommand": "javac -d bin src/*.java",
  
  // Tells Codespaces to wait until compilation is finished before executing the next step
  "waitFor": "onCreateCommand",
  
  // Automatically runs the main method immediately without requiring user input
  "postCreateCommand": "java -cp bin Main"
}
