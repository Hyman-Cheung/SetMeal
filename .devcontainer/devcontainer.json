{
  "name": "SetMeal POS System",
  "image": "mcr.microsoft.com/devcontainers/java:17",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17"
    }
  },
  "postCreateCommand": "javac -d build/classes src/SetMeal.java",
  "postStartCommand": "script -q -c 'java -cp build/classes SetMeal' /dev/null",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.scrollback": 10000
      }
    }
  }
}
