{
  "name": "Java SetMeal POS",
  "image": "mcr.microsoft.com/devcontainers/java:1-21-bullseye",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack"
      ]
    }
  },
  // FIX: This creates the 'bin' folder FIRST, then safely compiles your code
  "onCreateCommand": "mkdir -p bin && javac -d bin src/*.java",
  
  "waitFor": "onCreateCommand",
  "postCreateCommand": "java -cp bin Main"
}
