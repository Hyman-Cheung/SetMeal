{
  "name": "SetMeal POS System",
  "image": "mcr.microsoft.com/devcontainers/java:17",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17"
    }
  },
  "initializeCommand": "javac -d build/classes src/SetMeal.java",
  "onCreateCommand": "echo '✅ Java compiled!'",
  "postCreateCommand": "echo '✅ Ready! Running SetMeal...'",
  "postStartCommand": "java -cp build/classes SetMeal",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
