{
  "name": "Java SetMeal POS",
  "image": "mcr.microsoft.com/devcontainers/java:1-21-bullseye",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack"
      ]
    }
  },
  // FIX 1: Compiles all files inside your 'src/SetMeal' package directory into a 'bin' folder
  "onCreateCommand": "mkdir -p bin && javac -d bin src/SetMeal/*.java",
  
  "waitFor": "onCreateCommand",
  
  // FIX 2: Runs the program using the fully qualified name of your main class (SetMeal.Main)
  "postCreateCommand": "java -cp bin SetMeal.Main"
}
